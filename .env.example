# ---------------------------------------------------------------------------
# THE GARDEN DROP — environment
#
# The app runs with NONE of these set. In that mode it uses a zero-config local
# JSON store (.data/db.json), seeded from src/content/*. Email is logged to the
# console instead of sent. That is the right setup for a local mock-up.
#
# Add the variables below to graduate each subsystem to production.
# ---------------------------------------------------------------------------

# --- Site -------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Admin ------------------------------------------------------------------
# Password for /admin. CHANGE THIS. If unset, the dev default is: gardendrop
ADMIN_PASSWORD=gardendrop
# Random string used to sign the admin session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# --- Supabase (database, auth, storage) -------------------------------------
# When BOTH of the first two are present, the app reads/writes Supabase instead
# of the local JSON store. Run supabase/migrations/0001_init.sql first, then
# supabase/seed.sql.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser. Used by admin writes + subscriber inserts.
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (email) ---------------------------------------------------------
# When RESEND_API_KEY is present, welcome emails are actually sent.
RESEND_API_KEY=
RESEND_FROM="The Garden Drop <hello@thegardendrop.com>"
RESEND_REPLY_TO=hello@thegardendrop.com
# Optional: Resend Audience id, if you want subscribers mirrored into Resend.
RESEND_AUDIENCE_ID=

# --- Analytics (optional; pick one, or neither) -----------------------------
# Plausible
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_HOST=https://plausible.io
# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
